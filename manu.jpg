nstagram.fslz4-1.fna.fbcdn.net\/v\/t51.82787-15\/730942684_18609436495031624_9020574659219659038_n.jpg?stp=c0.168.1350.1350a_dst-jpg_e35_s150x150_tt6&_nc_cat=106&ig_cache_key=MzkyODQwMjc5MDA2OTI0MDY1NQ\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkZFRUQueHBpZHMuMTM1MC5zZHIucmVndWxhcl9waG90by5DMyJ9&_nc_ohc=qFkiLNtsBygQ7kNvwGINwxq&_nc_oc=AdpRUnIH_EVYRx9MW3vfMGQh4wx06luwTTGm1eyuNSRrL0PuHuHrSssKYcMLQg9h7OCzWuLvv8qHHxEbaK1-croe&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fslz4-1.fna&_nc_gid=ms9BTUaynbSZtS-b53Qq3g&_nc_ss=7a22e&oh=00_AQDMsCZ7HxI_XKHEmi0FbUYhFNHvjm95jdpvfZyyrGYysg&oe=6A5EFFA8","height":150,"width":150}]},"usertags":null,"taken_at":1782588305,"previous_submitter":null,"link":null,"story_cta":null,"like_count":4575,"organic_tracking_token":"","invited_coauthor_producers":[],"carousel_media_count":null,"all_previous_submitters":null,"coauthor_producers":[],"sponsor_tags":null,"follow_hashtag_info":null,"can_viewer_reshare":true,"ig_media_sharing_disabled":false,"like_and_view_counts_disabled":false,"comments_disabled":null,"feed_demotion_control":null,"feed_recs_demotion_control":{"title":"N\u00e3o tenho interesse","confirmation_body":"Vamos sugerir menos posts como este.","confirmation_icon":"none","confirmation_title":"Post oculto","confirmation_style":"tombstone_v2","confirmation_title_style":"large_left","followup_options":[{"id":"dont_suggest_posts_from_author","text":"N\u00e3o sugerir posts de aloisio","demotion_control":{"confirmation_body":"N\u00e3o vamos sugerir posts de aloisio.","confirmation_icon":"checkmark","confirmation_style":"tombstone_v2"}},{"id":"snooze_suggested_posts","text":"Ativar modo Soneca para todos os posts sugeridos no feed por 30 dias","demotion_control":{"confirmation_body":"N\u00e3o mostraremos posts sugeridos por 30 dias, a menos que voc\u00ea tenha visto todos os posts das contas que segue.","confirmation_icon":"checkmark","confirmation_style":"tombstone_v2"}},{"id":"this_post_makes_me_uncomfortable","text":"N\u00e3o me senti bem ao ver este post","demotion_control":{"confirmation_body":"Se voc\u00ea acha que este post n\u00e3o segue nossos Padr\u00f5es da Comunidade, fa\u00e7a uma den\u00fancia.","confirmation_icon":"checkmark","confirmation_style":"tombstone_v2"}}]},"ai_label_info":null,"ai_interactive_embodiment_attachment_style_info":null,"is_paid_partnership":false,"affiliate_info":null,"clips_attribution_info":null,"media_attributions_data":[],"clips_metadata":null,"location":null,"wearable_attribution_info":null,"caption":{"pk":"18013214705715126","text":"Hoje, o YouTube \u00e9 uma das maiores plataformas para quem quer aprender, se especializar e crescer de forma gratuita.\n\nEnquanto muita gente usa a internet s\u00f3 para entretenimento, outras pessoas est\u00e3o usando os mesmos v\u00eddeos para desenvolver habilidades que podem mudar completamente a carreira.\n\nPrograma\u00e7\u00e3o, IA, ciberseguran\u00e7a, UX, banco de dados, DevOps, AWS...\n\nNunca foi t\u00e3o f\u00e1cil aprender com profissionais que j\u00e1 est\u00e3o anos \u00e0 frente no mercado.\n\nMas o problema da maioria das pessoas n\u00e3o \u00e9 falta de informa\u00e7\u00e3o.\n\n\u00c9 falta de dire\u00e7\u00e3o.\n\nElas passam horas consumindo conte\u00fado, mas n\u00e3o sabem o que estudar, em qual ordem estudar e, principalmente, como transformar conhecimento em resultado.\n\nE \u00e9 isso que separa quem apenas aprende de quem constr\u00f3i uma carreira.\n\nPorque hoje, saber uma habilidade t\u00e9cnica j\u00e1 n\u00e3o \u00e9 suficiente.\n\nQuem mais cresce \u00e9 quem sabe aprender, aplicar e gerar resultado.\n\nE a internet est\u00e1 cheia de oportunidades para quem entende como usar conte\u00fado, canais e conhecimento do jeito certo.\n\nSe voc\u00ea quer aprender a usar o YouTube para construir renda, crescer canais e transformar conhecimento em oportunidade, me segue aqui pra n\u00e3o ficar pra tr\u00e1s.","has_translation":null},"caption_is_edited":false,"headline":null,"view_count":null,"top_likers":[],"facepile_top_likers":[],"hidden_likes_string_variant":-1,"fb_like_count":null,"crosspost_metadata":{"is_feedback_aggregated":null,"is_feed_feedback_aggregated":null},"social_context":[],"comment_count":21,"can_reshare":null,"enable_media_notes_production":false,"media_repost_count":null,"saved_collection_ids":null,"has_viewer_saved":null,"sharing_friction_info":{"should_have_sharing_friction":false,"bloks_app_url":null},"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"can_see_insights_as_brand":false,"has_audio":null,"media_notes":{"items":[]}},"view_state_item_type":null,"id":"3928402790069240655","inventory_source":"explore_story","ad":null},"end_of_feed_demarcator":null,"stories_netego":null,"suggested_users":null,"bloks_netego":null,"abra_icebreakers_in_feed_unit":null,"ad4ad_in_webfeed":null,"__typename":"XDTFeedItem"},"cursor":""},{"node":{"media":null,"ad":{"ad_id":"120251247106390249","global_position":2,"items":[{"id":"3925326279661054494_8727842505","item_client_gap_rules":{"post_gap_to_previous_ad":"3"},"pk":"3925326279661054494","social_context":null,"code":"DZ5j3Q-s-oe","inventory_source":"media_or_ad","logging_info_token":null,"explore":null,"main_feed_carousel_starting_media_id":null,"carousel_media":null,"audience":null,"is_seen":true,"media_type":1,"original_height":1402,"original_width":1122,"is_shared_from_basel":null,"floating_context_items":null,"has_liked":false,"open_carousel_submission_state":null,"media_overlay_info":null,"user":{"pk":"8727842505","profile_pic_url":"https:\/\/instagram.fslz4-1.fna.fbcdn.net\/v\/t51.82787-19\/746164596_18273338494290506_7299816272865187101_n.jpg?stp=dst-jpg_s150x150_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby4xMDgwLmMyIn0&_nc_ht=instagram.fslz4-1.fna.fbcdn.net&_nc_cat=102&_nc_oc=Q6cZ2gGd-aObGuBslKAlvJ4gHbputOIv0Lsud62nNFwzxniD0kLAvX2df4NfOrsFrUQKujhpT-mAi6KNSyHuiRJDabVS&_nc_ohc=96tkKZ2-HzwQ7kNvwFg36zq&_nc_gid=ms9BTUaynb